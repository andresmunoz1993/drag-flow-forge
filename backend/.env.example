# ─── Azure AD / Microsoft Graph ───────────────────────────────────────────────
# Obtener en: Azure Portal → App Registrations → Tu app → Overview y Certificates & secrets
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your-client-secret-here

# ─── Email ─────────────────────────────────────────────────────────────────────
# Dirección de correo desde la que se enviarán los emails.
# Debe ser un buzón válido del tenant con permiso "Mail.Send".
MAIL_SENDER=notificaciones@tudominio.com

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_db
# Usar un usuario dedicado (no postgres superuser) en producción
DATABASE_URL=postgresql://allers_app:CONTRASEÑA_SEGURA@localhost:5432/allers

# ─── JWT ───────────────────────────────────────────────────────────────────────
# OBLIGATORIO — el servidor no arranca sin este valor
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# NUNCA usar el mismo secret en dev y producción, NUNCA commitear este valor
JWT_SECRET=

# ─── SFTP (sincronización de documentos desde Windows) ────────────────────────
SFTP_HOST=
SFTP_PORT=22
SFTP_USER=
SFTP_PASSWORD=
SFTP_REMOTE_PATH=/pdfs
SFTP_PROCESSED_PATH=/pdfs/procesados
PDF_STORAGE_PATH=./storage/pdfs

# ─── SQL Server / SP Auto-Import (opcional — modo stub si no se configura) ────
SP_DB_SERVER=servidor.dominio.com
SP_DB_NAME=NombreBaseDeDatos
SP_DB_USER=usuario_sql
SP_DB_PASSWORD=contraseña_sql

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3001
# CORS_ORIGIN debe ser la URL exacta del frontend en producción (sin trailing slash)
CORS_ORIGIN=http://localhost:8080
NODE_ENV=development
