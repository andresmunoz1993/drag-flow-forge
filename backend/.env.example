# ─── Azure AD / Microsoft Graph ───────────────────────────────────────────────
# Tenant ID (Directory ID) de tu organización en Azure AD
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Application (client) ID del registro de app en Azure AD
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Client Secret generado en "Certificates & secrets" del registro de app
AZURE_CLIENT_SECRET=your-client-secret-here

# ─── Email ─────────────────────────────────────────────────────────────────────
# Dirección de correo desde la que se enviarán los emails.
# Debe ser un buzón válido del tenant con permiso "Mail.Send".
MAIL_SENDER=notificaciones@tudominio.com

# ─── SP Auto-Import (SQL Server) ───────────────────────────────────────────────
# Servidor SQL Server donde vive el SP de importación automática.
# Dejar vacío mientras el SP no esté listo; el servicio operará en modo stub.
SP_DB_SERVER=servidor.dominio.com
SP_DB_DATABASE=NombreBaseDeDatos
SP_DB_USER=usuario_sql
SP_DB_PASSWORD=contraseña_sql

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3001

# Origen permitido para CORS (URL del frontend)
CORS_ORIGIN=http://localhost:8080
