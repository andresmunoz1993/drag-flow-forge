# URL base del backend en producción.
# En desarrollo, Vite usa su proxy (/api → localhost:3001), así que no se necesita aquí.
# En producción, debe ser la URL pública del backend (sin trailing slash).
#
# Ejemplo si backend y frontend están en el mismo servidor con nginx:
#   VITE_BACKEND_URL=   (vacío — nginx hace el proxy /api en el mismo origen)
#
# Ejemplo si el backend está en un servidor/puerto diferente:
#   VITE_BACKEND_URL=https://allers-api.midominio.com
#
VITE_BACKEND_URL=
